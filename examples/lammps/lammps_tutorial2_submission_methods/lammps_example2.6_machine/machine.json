 {
   "run_command": "mpirun -np 4 lmp -in in.lammps",
   "machine": {
       "batch_type": "Slurm",
       "context_type": "Local",
       "local_root" : "./",
       "remote_root": "./" },
   "resources":{
       "number_node": 1,
       "cpu_per_node": 4,
       "gpu_per_node": 0,
       "queue_name": "apex_test",
       "group_size": 1,
       "module_list": ["deepmd-kit/2.1.0/cpu_binary_release"],
       "custom_flags": [
             "#SBATCH --partition=xlong",
             "#SBATCH --ntasks=1",
             "#SBATCH --mem=10G",
             "#SBATCH --nodes=1",
             "#SBATCH --time=1-00:00:00"
       ]
   }
 }
